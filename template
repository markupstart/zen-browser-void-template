# Template file for 'zen-browser'
pkgname=zen-browser
version=1.20.2b
revision=1
short_desc="A calmer, more privacy-focused Firefox-based browser"
maintainer="Mark <mark@example.com>"
license="MPL-2.0"
homepage="https://zen-browser.com"
changelog="https://github.com/zen-browser/desktop/releases"
distfiles="https://github.com{version}/zen.linux-x86_64.tar.xz"
checksum=36ad444c06c22b0ea1d3d1d15013f32bc9ce6ea907070ab277f700fde0bc1674

# CRITICAL: This tells xbps-src to operate directly inside the extracted 'zen/' root directory
wrksrc="zen"

lib32disabled=yes
depends="gtk+3 libXrender libXcomposite libXdamage libXfixes libX11 libXtst dbus
 libnotify"

do_install() {
	# 1. Safely create the target directory layout
	vmkdir opt/zen-browser
	
	# 2. Copy EVERYTHING from the current directory (.) into the destination folder
	# Since wrksrc="zen", the "." target represents the true archive root containing all assets
	cp -a . "${DESTDIR}/opt/zen-browser"

	# 3. Create a system path link so the desktop file launcher finds it
	vmkdir usr/bin
	ln -s /opt/zen-browser/zen "${DESTDIR}/usr/bin/zen-browser"

	# 4. Install the desktop configuration file
	vmkdir usr/share/applications
	cat > ${DESTDIR}/usr/share/applications/zen-browser.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=Zen Browser
Comment=A calmer, more privacy-focused web browser
Exec=zen-browser %u
Icon=zen-browser
Terminal=false
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;application/xml;application/rss+xml;application/atom+xml;
EOF

	# 5. Extract and drop the sizing icons into the system environment
	for size in 16 32 48 64 128 256; do
		if [ -f "browser/chrome/icons/default/default${size}.png" ]; then
			vmkdir usr/share/icons/hicolor/${size}x${size}/apps
			vcopy browser/chrome/icons/default/default${size}.png \
				usr/share/icons/hicolor/${size}x${size}/apps/zen-browser.png
		fi
	done
}
